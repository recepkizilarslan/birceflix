{
  "name": "birceflix",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run -w frontend dev",
    "dev:backend": "npm run -w backend dev",
    "dev": "concurrently -k -n frontend,backend -c cyan,magenta \"npm:dev:frontend\" \"npm:dev:backend\"",
    "build:frontend": "npm run -w frontend build",
    "build:backend": "npm run -w backend build",
    "build": "npm run build:frontend && npm run build:backend",
    "lint": "npm run -w frontend lint",
    "typecheck": "npm run -w frontend typecheck && npm run -w backend typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
