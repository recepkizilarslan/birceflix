# For prod, replace {$DOMAIN:localhost} with your real domain.
# Caddy will provision a Let's Encrypt cert automatically if a public
# domain + port 80/443 are reachable. For localhost dev, it serves over
# http(s) with a self-signed cert.

{$DOMAIN:localhost} {
  encode zstd gzip

  # API → backend
  handle /api/* {
    reverse_proxy api:3000
  }

  # SPA. Caddy serves the Vite build directly (baked into the image at
  # /srv, see caddy/Dockerfile). No separate nginx layer. Unknown paths
  # fall back to index.html so React Router can resolve them.
  handle {
    root * /srv

    # Cache policy lives here so there is a single answer to "why does the
    # site look different for different people": hashed asset filenames are
    # content-addressed, so they are immutable and cached for a year, while
    # index.html (and everything else, including sw.js) is never stored.
    # Every visit re-fetches the current shell, which references the
    # current asset hashes, so there is no stale-shell skew across users.
    @assets path /assets/*
    @notassets not path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
    header @notassets Cache-Control "no-store"

    try_files {path} /index.html
    file_server
  }

  # Security headers. Caddy is the single web tier that fronts both /api
  # and the SPA, so the policy lives here as the single source of truth.
  #
  # CSP origins:
  #   image.tmdb.org              — poster/backdrop/logo CDN
  #   *.googleusercontent.com     — Google profile avatars after OAuth
  #   fonts.googleapis.com/.gstatic.com — Bebas Neue webfont
  # form-action allows the Google OAuth start redirect to accounts.google.com.
  header {
    -Server
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "interest-cohort=(), geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()"
    Cross-Origin-Opener-Policy "same-origin"
    Cross-Origin-Resource-Policy "same-origin"
    X-Permitted-Cross-Domain-Policies "none"
    Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://accounts.google.com; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://image.tmdb.org https://*.googleusercontent.com; connect-src 'self'; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests"
  }

  log {
    output stdout
    format console
  }
}
