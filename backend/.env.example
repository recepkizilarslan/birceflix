NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgres://birceflix:birceflix@localhost:5432/birceflix

# `openssl rand -base64 48` — KEEP SECRET
SESSION_SECRET=
SESSION_COOKIE_NAME=birceflix_session
SESSION_TTL_DAYS=30

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Server-side third-party keys (never shipped to the browser)
TMDB_API_KEY=
OMDB_API_KEY=

# Optional: Trakt integration. Leave blank to disable.
# 1. https://trakt.tv/oauth/applications/new → create an app.
# 2. Redirect URI must match TRAKT_REDIRECT_URI below exactly.
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://localhost:3000/api/integrations/trakt/callback

FRONTEND_ORIGIN=http://localhost:5173
DEFAULT_WATCH_REGION=TR
