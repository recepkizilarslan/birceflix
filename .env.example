# Copy to `.env` and fill in. Used by docker-compose.

# Domain Caddy should serve (use a real domain in prod, "localhost" for dev)
DOMAIN=localhost

# --- Database ---
DB_PASSWORD=change-me-strong

# --- Sessions ---
# Generate: `openssl rand -base64 48`
SESSION_SECRET=change-me-at-least-32-characters-long

# --- Google OAuth ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized Redirect URI on Google's side.
# Prod example: https://birceflix.example.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# --- Third-party APIs (server-side only) ---
TMDB_API_KEY=
OMDB_API_KEY=

# --- Frontend ---
# Origin used for CORS + the post-login redirect target.
# In prod, this is the same as the Caddy-served domain (https://...).
FRONTEND_ORIGIN=http://localhost

# --- Regional defaults ---
DEFAULT_WATCH_REGION=TR
